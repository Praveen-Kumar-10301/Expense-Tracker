# --- Local development ---
PORT=3001
NODE_ENV=development
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-32-chars
CLIENT_URL=http://localhost:5173

# --- Database ---
# Leave the Turso vars blank for local dev: the server falls back to a local
# SQLite file at server/db/expense_tracker.db.
# In production (Render), set these to your Turso database:
#   TURSO_DATABASE_URL=libsql://your-db-name-yourorg.turso.io
#   TURSO_AUTH_TOKEN=your-turso-auth-token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# In production set:
#   NODE_ENV=production
#   PORT is provided by the host automatically
#   CLIENT_URL=https://your-app.onrender.com   (same origin as the API)
